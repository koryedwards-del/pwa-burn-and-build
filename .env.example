# Local program creator (copy to .env — never commit .env)
PORT=3001
NODE_ENV=development

# Cross-service URLs (local defaults)
WEBPAGE_URL=http://localhost:3000
CREATOR_BASE_URL=http://localhost:3001

# Future — set in Render dashboard only (Environment), never commit values
# DATABASE_PATH=server/data/programs.db
# CONTACTS_ADMIN_KEY=
# STRIPE_SECRET_KEY=
# SIGNAL_PLUS_API_KEY=
# PROGRAM_SIGNING_SECRET=
#
# After first deploy, set CREATOR_BASE_URL to your Render URL, e.g.:
# CREATOR_BASE_URL=https://program-creator-3tzd.onrender.com
