# Local program creator (copy to .env — never commit .env)
PORT=3001
NODE_ENV=development

# Cross-service URLs (local defaults)
WEBPAGE_URL=http://localhost:3000
CREATOR_BASE_URL=http://localhost:3001

# Production (Render dashboard + render.yaml):
# plan: starter (always on — no cold-start sleep)
# DATABASE_PATH=/var/data/programs.db  (persistent disk)
# CREATOR_BASE_URL=https://burnandbuilddiet.com
# WEBPAGE_URL=https://burnandbuilddiet.com
# API_BASE_URL=https://program-creator-3tzd.onrender.com
# CONTACTS_ADMIN_KEY=...               (required in production)
# CORS_ORIGINS=                        ← extra allowed origins (comma-separated)

# Stripe Checkout ($149 product + promo codes in Dashboard)
# STRIPE_SECRET_KEY=sk_live_... or sk_test_...
# STRIPE_PRICE_ID=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_TEST_BYPASS=0                   ← keep off in production
