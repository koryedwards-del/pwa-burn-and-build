# Local program creator (copy to .env — never commit .env)
PORT=3001
NODE_ENV=development

# Cross-service URLs (local defaults)
WEBPAGE_URL=http://localhost:3000
CREATOR_BASE_URL=http://localhost:3001

# Production (Render dashboard):
# CREATOR_BASE_URL=https://gettheburnandbuildapp.com   ← Stripe return URLs land here
# WEBPAGE_URL=https://gettheburnandbuildapp.com
# CORS_ORIGINS=                                          ← extra allowed origins (comma-separated)

# Future — set in Render dashboard only (Environment), never commit values
# DATABASE_PATH=server/data/programs.db
# CONTACTS_ADMIN_KEY=
#
# Stripe Checkout ($149 product + promo codes in Dashboard)
# Use TEST keys from Stripe → Developers → API keys while integrating
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRICE_ID=price_...        ← Price ID for $149 (not Product ID)
# STRIPE_WEBHOOK_SECRET=whsec_...  ← Step 2: webhook endpoint signing secret
# STRIPE_TEST_BYPASS=1             ← Optional: allow "Skip payment (test)" on Render
#
# SIGNAL_PLUS_API_KEY=
# PROGRAM_SIGNING_SECRET=
#
# After first deploy, set CREATOR_BASE_URL to your public creator URL, e.g.:
# CREATOR_BASE_URL=https://gettheburnandbuildapp.com
